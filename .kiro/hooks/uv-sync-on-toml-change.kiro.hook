{
  "enabled": true,
  "name": "UV Sync on pyproject.toml change",
  "description": "pyproject.toml o'zgarganda uv sync qilishni eslatadi",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "pyproject.toml"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "pyproject.toml o'zgardi. Foydalanuvchiga 'uv sync' buyrug'ini ishga tushirishni eslatib qo'y."
  }
}
